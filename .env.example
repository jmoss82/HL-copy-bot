# -- Your HyperLiquid Wallet ------------------------------------
HL_WALLET_ADDRESS=0xYOUR_WALLET_ADDRESS
HL_PRIVATE_KEY=0xYOUR_PRIVATE_KEY
HL_ACCOUNT_ADDRESS=0xYOUR_ACCOUNT_ADDRESS

# -- Target Trader ----------------------------------------------
COPY_TARGET_ADDRESS=0x3454c7aa653c908850021eff43c0a141cd138c9e

# -- Scaling ----------------------------------------------------
#   "proportional"   - (your equity / their equity) * their delta
#   "fixed_ratio"    - their delta * ratio
#   "fixed_size"     - always trade COPY_FIXED_SIZE per signal
#   "fixed_notional" - always trade COPY_FIXED_NOTIONAL_USD per signal
COPY_SCALING_MODE=fixed_notional
COPY_FIXED_NOTIONAL_USD=20
COPY_MAX_TRADE_USD=40

# -- Risk -------------------------------------------------------
COPY_LEVERAGE=5
COPY_IS_CROSS=false

# -- Execution --------------------------------------------------
COPY_POLL_INTERVAL=3.0
# "state" (recommended): reconcile desired position each poll
# "delta": react only to detected changes between polls
COPY_RECONCILE_MODE=state
COPY_SLIPPAGE_BPS=10.0
COPY_MIN_TRADE_USD=11.0

# -- Coins ------------------------------------------------------
COPY_COINS=APT,MON,BERA,ZRO,GRASS,VVV

# -- Startup ----------------------------------------------------
COPY_SYNC_STARTUP=true

# -- Safety -----------------------------------------------------
COPY_MAX_DAILY_TRADES=200
COPY_DRY_RUN=false

# -- Logging ----------------------------------------------------
COPY_LOG_LEVEL=INFO
